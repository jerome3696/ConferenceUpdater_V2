#!/usr/bin/env bash
# 머지 후 feature/PLAN-xxx 플랜 문서를 active/ → completed/ 자동 이동
# 지원 형식:
#   - PLAN-NNN          (숫자 ID)
#   - PLAN-P0-<slug>    (Phase A.0 준비기 skeleton)
#   - PLAN-P0-<slug>-vN (-vN 접미사는 제거하고 slug 로만 아카이브)

MERGE_MSG=$(git log -1 --pretty=%s)

PLAN_ID=""
if [[ "$MERGE_MSG" =~ (PLAN-P0-[a-z][a-z0-9-]*) ]]; then
  PLAN_ID="${BASH_REMATCH[1]}"
  # 브랜치명에 붙은 -vN 접미사 제거 (예: PLAN-P0-multitenant-schema-v1 → PLAN-P0-multitenant-schema)
  PLAN_ID="${PLAN_ID%-v[0-9]*}"
elif [[ "$MERGE_MSG" =~ PLAN-([0-9]+) ]]; then
  PLAN_ID="PLAN-${BASH_REMATCH[1]}"
fi

if [[ -n "$PLAN_ID" ]]; then
  PLAN_FILE="docs/plans/active/${PLAN_ID}.md"
  DEST_FILE="docs/plans/completed/${PLAN_ID}.md"

  if [[ -f "$PLAN_FILE" ]]; then
    echo ""
    echo "📦 플랜 아카이브: $PLAN_ID → completed/"
    git mv "$PLAN_FILE" "$DEST_FILE"
    git commit -m "chore: move ${PLAN_ID} to completed"
    echo "✅ $PLAN_ID 완료 처리됨"
    echo ""
  elif [[ -f "$DEST_FILE" ]]; then
    echo "ℹ️  $PLAN_ID 이미 completed/ 에 있음 — 건너뜀"
  fi
fi
