# Copy this file to `.env` and replace the placeholder with your real key.
# `.env` is gitignored — never commit real secrets.

# ── 레거시 (PLAN-029 이전까지 브라우저 직접 호출용) ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── PLAN-028 Supabase (서버측, scripts/ 용 · service_role 브라우저 노출 금지) ──
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── PLAN-029 예정 (Vite — VITE_ prefix 만 브라우저 노출) ──
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
VITE_EDGE_FUNCTION_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/claude-proxy

# ── Edge Function secrets 는 `supabase secrets set` 로 별도 등록 ──
# supabase secrets set ANTHROPIC_API_KEY=<your-key>
# supabase secrets set MONTHLY_BUDGET_CAP_USD=50
# supabase secrets set CACHE_TTL_DAYS=30
